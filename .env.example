# =====================================
# OmniTranslate 环境变量配置
# =====================================
# 复制此文件为 .env 并填入实际值
# 注意：API 配置（API Key、Base URL、Model）请在网页的设置页面中配置

# 后端配置
# 允许的 CORS 来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库配置
# SQLite 数据库路径（相对于项目根目录）
DATABASE_URL=sqlite+aiosqlite:///./backend/data/omni.db

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 文件上传限制（字节）
MAX_FILE_SIZE=104857600

# 翻译服务配置
# 翻译重试次数
MAX_RETRIES=3

# 请求间隔（秒），用于避免 API 速率限制
REQUEST_INTERVAL=1

# === Translation control ===
TRANSLATION_CONCURRENCY=8
TRANSLATION_TEMPERATURE=0.25
TRANSLATION_MAX_TOKENS=4096
TRANSLATION_DELAY_SECONDS=0
PROGRESS_UPDATE_INTERVAL=5
AUTO_RETRY_QA_FAILED=true
AUTO_RETRY_MAX_PER_SEG=1

# === Batching ===
TRANSLATION_BATCH_SIZE=4
TRANSLATION_BATCH_MAX_CHARS=2400

# === Context window ===
CTX_PREV_SEGS=3
CTX_NEXT_SEGS=2
CTX_PREV_MAX_CHARS=600
CTX_NEXT_MAX_CHARS=400

# === Glossary ===
GLOSSARY_EXPAND_EVERY=3

# === PDF parser ===
PDF_MERGE_BLOCKS=true
PDF_SKIP_HEADER_FOOTER=true
PDF_HEADER_FOOTER_MARGIN=40
PDF_SEGMENT_MAX_CHARS=1600
PDF_SEGMENT_MIN_CHARS=80
PDF_MIN_FONT_SIZE=7.0

# === PDF exporter ===
PDF_FIRST_LINE_INDENT=true
CN_FONT_FILE=backend/data/fonts/SourceHanSerifSC-Regular.otf
CN_FONT_BOLD_FILE=backend/data/fonts/SourceHanSerifSC-Bold.otf
CN_FONT_NAME=SHSerif
CN_FONT_BOLD=SHSerifBold